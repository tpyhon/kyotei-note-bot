# 環境変数（絶対にコミットしない）
.env

# データキャッシュ（生データ・加工済みデータはGit管理外）
data/raw/*
data/processed/*
data/results/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/results/.gitkeep

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# ログ
*.log
